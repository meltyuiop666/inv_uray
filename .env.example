# ─── Django Core ────────────────────────────────────────────────────────────
# Generate dengan: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-secret-key-change-this

# Set ke False di production
DEBUG=False

# Domain kamu, pisah dengan koma. Contoh: lookatstore.example.com,www.lookatstore.example.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database PostgreSQL ─────────────────────────────────────────────────────
DB_NAME=db_lookatstore
DB_USER=postgres
DB_PASSWORD=ganti_password_aman_ini

# ─── Gunicorn ────────────────────────────────────────────────────────────────
# Rekomendasi: (2 x jumlah_CPU) + 1
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# ─── Nginx ───────────────────────────────────────────────────────────────────
# Port host yang di-expose (Coolify akan override ini lewat proxy-nya)
NGINX_PORT=80
